{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homespun.local/schemas/worker/inventory-log-record/1.0.0.json",
  "title": "SessionInventoryLogRecord",
  "description": "JSON payload embedded in the worker's 'inventory event=... sessionId=... payload={...}' log line. Emitted once per session create, session resume, and worker boot. See specs/001-worker-skills-logging/data-model.md for field-level rationale. This schema is the stable contract referenced by FR-008; changes require a spec update.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "cwd",
    "timestamp",
    "settingSources",
    "skills",
    "plugins",
    "commands",
    "agents",
    "hooks",
    "mcpServers",
    "discoveryErrors"
  ],
  "properties": {
    "event": {
      "type": "string",
      "enum": ["create", "resume", "boot"],
      "description": "Which session-lifecycle event triggered this record."
    },
    "sessionId": {
      "type": "string",
      "minLength": 1,
      "description": "Worker session id (randomUUID). For boot events this field is the literal string 'boot'."
    },
    "cwd": {
      "type": "string",
      "minLength": 1,
      "description": "Working directory used for SDK discovery. Home-relative (~/...) or repo-relative where possible."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 emission time."
    },
    "sdkVersion": {
      "type": "string",
      "description": "claude_code_version reported by the SDK init message, when available."
    },
    "model": {
      "type": "string"
    },
    "permissionMode": {
      "type": "string",
      "enum": ["default", "acceptEdits", "plan", "bypassPermissions"]
    },
    "settingSources": {
      "type": "array",
      "items": { "type": "string", "enum": ["user", "project", "local"] },
      "uniqueItems": true
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/resourceInventoryEntry" }
    },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/$defs/resourceInventoryEntry" }
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/resourceInventoryEntry" }
    },
    "agents": {
      "type": "array",
      "items": { "$ref": "#/$defs/resourceInventoryEntry" }
    },
    "hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/resourceInventoryEntry" }
    },
    "mcpServers": {
      "type": "array",
      "items": { "$ref": "#/$defs/resourceInventoryEntry" }
    },
    "discoveryErrors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "source", "reason"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["skill", "plugin", "command", "agent", "hook", "mcpServer"]
          },
          "source": {
            "type": "string",
            "description": "Short identifier of the discovery source that failed (e.g. 'fs:~/.claude/hooks')."
          },
          "reason": {
            "type": "string",
            "description": "Sanitized error description. MUST NOT contain secret material."
          }
        }
      }
    },
    "truncated": {
      "type": "boolean"
    },
    "truncationCounts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["emitted", "total"],
        "properties": {
          "emitted": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "event": { "const": "boot" } }
      },
      "then": {
        "properties": {
          "sessionId": { "const": "boot" }
        }
      },
      "else": {
        "required": ["sessionId"]
      }
    },
    {
      "if": {
        "required": ["truncated"],
        "properties": { "truncated": { "const": true } }
      },
      "then": {
        "required": ["truncationCounts"]
      }
    }
  ],
  "$defs": {
    "resourceInventoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "name", "scope"],
      "properties": {
        "category": {
          "type": "string",
          "enum": ["skill", "plugin", "command", "agent", "hook", "mcpServer"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": ["user", "project", "plugin", "inline", "unknown"]
        },
        "sourcePath": {
          "type": "string",
          "description": "Relative or home-relative path. MUST NOT be an absolute path outside the user's home (except /workdir and its descendants)."
        },
        "providedByPlugin": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the providing plugin, when scope === 'plugin'."
        },
        "enabled": {
          "type": "boolean"
        },
        "transport": {
          "type": "string",
          "enum": ["stdio", "sse", "http", "sdk"],
          "description": "Only present for mcpServer entries."
        },
        "status": {
          "type": "string",
          "enum": ["configured", "unavailable", "enabled"],
          "description": "Only present for mcpServer entries."
        },
        "statusDetail": {
          "type": "string",
          "description": "Only present when status === 'unavailable'. MUST NOT contain secret material."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "scope": { "const": "plugin" } },
            "required": ["scope"]
          },
          "then": {
            "required": ["providedByPlugin"]
          }
        },
        {
          "if": {
            "properties": { "category": { "const": "mcpServer" } },
            "required": ["category"]
          },
          "then": {
            "required": ["transport", "status"]
          }
        }
      ]
    }
  }
}
