model {

  extend homespun {

    server = container 'ASP.NET Server' {
      description 'Backend API, SignalR hubs, agent orchestration (port 8080)'
      technology 'ASP.NET / C#'
    }

    web = container 'React Frontend' {
      description 'Nginx container serving the built React SPA (port 3001)'
      technology 'React / TypeScript / Nginx'
    }

    worker = container 'TypeScript Worker' {
      description 'Sidecar for mini prompts and lightweight AI tasks'
      technology 'Hono / Claude Agent SDK'
    }

    loki = container 'Loki' {
      #vm
      description 'Log aggregation service'
      technology 'Grafana Loki'
    }

    promtail = container 'Promtail' {
      #vm
      description 'Log collector agent'
      technology 'Grafana Promtail'
    }

    grafana = container 'Grafana' {
      #vm
      description 'Observability dashboards'
      technology 'Grafana'
    }

    data_volume = database '/data Volume' {
      description 'JSON/JSONL project and feature data'
    }

    fleece_store = database '.fleece/ Store' {
      description 'Fleece issue tracking JSONL files'
    }

  }

  // Container relationships
  web -> server 'REST API + SignalR'
  server -> worker 'HTTP requests'
  server -> docker_engine 'Spawns agent containers (DooD)'
  server -> github 'Octokit REST API'
  server -> claude_api 'Claude Code sessions'
  server -> data_volume 'Reads/writes project data'
  server -> fleece_store 'Reads/writes issue data'
  worker -> claude_api 'Anthropic SDK calls'
  promtail -> loki 'Pushes logs'
  grafana -> loki 'Queries logs'
  developer -> web 'Browser'

}
