{
  "MockMode": {
    "Enabled": true,
    "SeedData": true,
    "UseLiveClaudeSessions": true,
    "LiveClaudeSessionsWorkingDirectory": null
  },
  "AgentExecution": {
    "Mode": "Local",
    "SingleContainer": {
      "ForceContainerWorkingDirectory": "/workdir"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Homespun.Features.Testing": "Debug",
      "Homespun.Features.ClaudeCode": "Debug"
    }
  },
  "SessionEventContent": {
    "ContentPreviewChars": 240
  },
  "TaskGraphSnapshot": {
    "Enabled": true,
    "RefreshIntervalSeconds": 10,
    "IdleEvictionMinutes": 5
  }
}
