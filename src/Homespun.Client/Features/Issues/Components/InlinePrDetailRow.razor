@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

@inject HttpIssueApiService IssueApi
@inject HttpSessionApiService SessionStoreApi
@inject HttpSessionApiService SessionApi
@inject HttpAgentPromptApiService AgentPromptApi
@inject HttpPullRequestApiService PullRequestApi
@inject HttpProjectApiService ProjectApi
@inject HttpCloneApiService CloneApi
@inject NavigationManager NavigationManager
@inject ILogger<InlinePrDetailRow> Logger
@inject IMarkdownRenderingService MarkdownService

<div class="inline-pr-detail" data-testid="inline-pr-detail" @onclick:stopPropagation="true">
    <div class="inline-pr-detail-header">
        @if (IsMerged)
        {
            <BbBadge Class="bg-purple-500 text-white border-transparent">Merged</BbBadge>
        }
        else if (CurrentPr != null)
        {
            <BbBadge Class="@GetStatusBadgeClass()">@CurrentPr.Status</BbBadge>
        }

        @if (GetGitHubUrl() is { } url)
        {
            <a href="@url" target="_blank" style="text-decoration: none;" @onclick:stopPropagation="true">
                <BbBadge Variant="BadgeVariant.Secondary">
                    PR #@GetPrNumber()
                </BbBadge>
            </a>
        }
        else
        {
            <BbBadge Variant="BadgeVariant.Secondary">PR #@GetPrNumber()</BbBadge>
        }

        @if (!IsMerged)
        {
            @if (_isStarting)
            {
                <BbBadge Class="bg-amber-500 text-white border-transparent">
                    <BbSpinner Size="SpinnerSize.Small" Class="mr-1" />
                    Starting...
                </BbBadge>
            }
            else if (_session != null)
            {
                <BbBadge Class="bg-green-600 text-white border-transparent">Session Active</BbBadge>
            }
        }

        <div class="inline-pr-detail-header-spacer"></div>

        <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="HandleClose" title="Close details">
            <LucideIcon Name="x" Size="14" />
        </BbButton>
    </div>

    <div class="inline-pr-detail-info">
        @if (!string.IsNullOrEmpty(GetBranchName()))
        {
            <div class="inline-pr-detail-info-item">
                <span class="inline-pr-detail-label">Branch</span>
                <code class="inline-pr-detail-value">@GetBranchName()</code>
            </div>
        }
        @if (IsMerged && MergedPr?.PullRequest.MergedAt.HasValue == true)
        {
            <div class="inline-pr-detail-info-item">
                <span class="inline-pr-detail-label">Merged</span>
                <span class="inline-pr-detail-value">@MergedPr.PullRequest.MergedAt.Value.ToLocalTime().ToString("g")</span>
            </div>
        }
        else if (CurrentPr != null)
        {
            <div class="inline-pr-detail-info-item">
                <span class="inline-pr-detail-label">Updated</span>
                <span class="inline-pr-detail-value">@CurrentPr.UpdatedAt.ToLocalTime().ToString("g")</span>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(GetDescription()))
    {
        <div class="inline-pr-detail-description markdown-content">
            @((MarkupString)MarkdownService.RenderToHtml(GetDescription()!))
        </div>
    }

    @* Linked Issue Section *@
    @if (_linkedIssue != null)
    {
        <div class="inline-pr-detail-linked-issue">
            <div class="inline-pr-detail-linked-issue-header">
                <BbBadge Class="bg-blue-500 text-white border-transparent">@_linkedIssue.Id</BbBadge>
                <span class="text-text-muted text-sm">Linked Issue</span>
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" Href="@($"/projects/{ProjectId}/issues/{_linkedIssue.Id}/edit")" @onclick:stopPropagation="true">
                    <LucideIcon Name="pencil" Size="12" />
                </BbButton>
            </div>
            <p class="mb-1 font-bold text-sm">@_linkedIssue.Title</p>
            <div class="mb-1">
                <BbBadge Class="@GetIssueTypeBadgeClass(_linkedIssue.Type)">@_linkedIssue.Type</BbBadge>
                <BbBadge Class="@GetIssueStatusBadgeClass(_linkedIssue.Status)">@_linkedIssue.Status</BbBadge>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(GetLinkedIssueId()))
    {
        <div class="inline-pr-detail-linked-issue">
            <BbBadge Class="bg-blue-500 text-white border-transparent">@GetLinkedIssueId()</BbBadge>
            <span class="text-text-muted text-sm">Linked Issue (not found)</span>
        </div>
    }

    @if (!IsMerged && _session != null)
    {
        <div class="inline-pr-detail-session">
            <BbBadge Class="@GetSessionStatusBadgeClass()">@_session.Status</BbBadge>
            <small class="text-text-muted ml-2">
                Mode: <code>@_session.Mode</code> | Model: <code>@GetModelDisplayName(_session.Model)</code>
            </small>
        </div>
    }

    @if (!IsMerged && CurrentPr != null)
    {
        <SessionCacheHistory
            EntityId="@CurrentPr.Id"
            ProjectId="@CurrentPr.ProjectId"
            WorkingDirectory="@CurrentPr.ClonePath"
            ShowBorder="true"
            ShowEmptyState="false" />
    }

    <div class="inline-pr-detail-actions">
        @if (!IsMerged && CurrentPr != null)
        {
            @if (CurrentPr.Status == OpenPullRequestStatus.ReadyForReview)
            {
                <BbButton Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" OnClick="SkipReview" Disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <BbSpinner Size="SpinnerSize.Small" Class="mr-1" />
                    }
                    Skip Review
                </BbButton>
            }

            @if (_isStarting)
            {
                <BbButton Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" Disabled="true">
                    <BbSpinner Size="SpinnerSize.Small" Class="mr-1" />
                    Starting Session...
                </BbButton>
            }
            else if (_session != null)
            {
                <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" Href="@($"/session/{_session.Id}")" @onclick:stopPropagation="true">
                    Open Chat
                </BbButton>
                <BbButton Variant="ButtonVariant.Destructive" Size="ButtonSize.Small" OnClick="StopSession" Disabled="@_isSessionLoading">
                    @if (_isSessionLoading)
                    {
                        <BbSpinner Size="SpinnerSize.Small" Class="mr-1" />
                    }
                    Stop Session
                </BbButton>
            }
            else
            {
                <div class="inline-pr-detail-agent-controls">
                    <ModelSelector Id="@($"pr-model-{CurrentPr.Id}")"
                                   SelectedModel="@_selectedModel"
                                   SelectedModelChanged="OnModelChanged" />
                    <AgentSelector
                        ProjectId="@CurrentPr.ProjectId"
                        Disabled="@StartSessionDisabled"
                        IsStarting="@_isStarting"
                        OnStart="HandleAgentStart" />
                </div>

                @if (_cloneInfo != null && _branchInfo?.BehindCount > 0)
                {
                    <BbButton Variant="ButtonVariant.Secondary" Size="ButtonSize.Small"
                            OnClick="StartRebaseAsync"
                            Disabled="@(_isRebasing || _isStarting)">
                        @if (_isRebasing)
                        {
                            <BbSpinner Size="SpinnerSize.Small" Class="mr-1" />
                        }
                        Rebase onto @_project?.DefaultBranch (@_branchInfo.BehindCount behind)
                    </BbButton>
                }
            }

            @if (CurrentPr is { Status: OpenPullRequestStatus.Approved, GitHubPRNumber: not null })
            {
                <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" OnClick="MergePullRequest" Disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <BbSpinner Size="SpinnerSize.Small" Class="mr-1" />
                    }
                    Merge
                </BbButton>
            }
        }
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <BbAlert Variant="AlertVariant.Danger" Class="mt-2 mb-0">
            <BbAlertDescription>@_errorMessage</BbAlertDescription>
        </BbAlert>
    }
</div>

<style>
    .inline-pr-detail {
        background: var(--bg-secondary);
        border-left: 3px solid #8b5cf6;
        padding: 1rem;
        margin: 0.25rem 0;
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        animation: inlinePrDetailExpandIn 0.2s ease-out;
    }

    @@keyframes inlinePrDetailExpandIn {
        from {
            opacity: 0;
            transform: translateY(-8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .inline-pr-detail-header {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
        margin-bottom: 0.75rem;
    }

    .inline-pr-detail-header-spacer {
        flex: 1;
    }

    .inline-pr-detail-info {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 0.75rem;
        font-size: 0.875rem;
    }

    .inline-pr-detail-info-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .inline-pr-detail-label {
        color: var(--text-muted);
    }

    .inline-pr-detail-value {
        color: var(--text-primary);
    }

    .inline-pr-detail-description {
        margin-bottom: 0.75rem;
        max-height: 200px;
        overflow-y: auto;
        padding: 0.75rem;
        background: var(--bg-primary);
        border-radius: var(--radius-sm);
        border: 1px solid var(--border-color);
    }

    .inline-pr-detail-linked-issue {
        margin-bottom: 0.75rem;
        padding: 0.5rem;
        background: var(--bg-tertiary);
        border-radius: var(--radius-sm);
        border: 1px solid var(--border-color);
    }

    .inline-pr-detail-linked-issue-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .inline-pr-detail-session {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 0.75rem;
        padding: 0.5rem;
        background: var(--bg-tertiary);
        border-radius: var(--radius-sm);
    }

    .inline-pr-detail-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        border-top: 1px solid var(--border-color);
        padding-top: 0.75rem;
        margin-top: 0.75rem;
    }

    .inline-pr-detail-agent-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
    }

    @@media (max-width: 768px) {
        .inline-pr-detail {
            padding: 0.75rem;
        }

        .inline-pr-detail-info {
            flex-direction: column;
            gap: 0.5rem;
        }

        .inline-pr-detail-actions {
            flex-direction: column;
        }

        .inline-pr-detail-actions > * {
            width: 100%;
        }

        .inline-pr-detail-agent-controls {
            flex-direction: column;
            width: 100%;
        }
    }
</style>

@code {
    [Parameter] public required string ProjectId { get; set; }

    [Parameter] public PullRequest? CurrentPr { get; set; }

    [Parameter] public MergedPullRequestDetails? MergedPr { get; set; }

    [Parameter] public EventCallback OnActionCompleted { get; set; }

    [Parameter] public EventCallback OnClose { get; set; }

    private bool IsMerged => MergedPr != null;

    private bool _isLoading;
    private string? _errorMessage;
    private bool _isSessionLoading;
    private ClaudeSession? _session;
    private string _selectedModel = "opus";
    private Project? _project;
    private CloneInfo? _cloneInfo;
    private BranchInfo? _branchInfo;
    private bool _isRebasing;
    private bool _isStarting;
    private IssueResponse? _linkedIssue;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        if (!IsMerged)
        {
            _ = SetupSignalRConnectionAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!IsMerged && CurrentPr != null)
        {
            await RefreshSessionStatusAsync();
            await LoadCloneInfoAsync();
        }
        await LoadLinkedIssueAsync();
    }

    private int? GetPrNumber() => IsMerged ? MergedPr?.PullRequest.Number : CurrentPr?.GitHubPRNumber;

    private string? GetGitHubUrl()
    {
        if (IsMerged)
            return MergedPr?.PullRequest.HtmlUrl;

        if (CurrentPr?.GitHubPRNumber.HasValue == true && CurrentPr.Project != null)
            return $"https://github.com/{CurrentPr.Project.GitHubOwner}/{CurrentPr.Project.GitHubRepo}/pull/{CurrentPr.GitHubPRNumber}";

        return null;
    }

    private string? GetBranchName() => IsMerged ? MergedPr?.PullRequest.BranchName : CurrentPr?.BranchName;

    private string? GetDescription() => IsMerged ? MergedPr?.PullRequest.Body : CurrentPr?.Description;

    private string? GetLinkedIssueId() => IsMerged ? MergedPr?.LinkedIssueId : CurrentPr?.BeadsIssueId;

    private async Task LoadLinkedIssueAsync()
    {
        _linkedIssue = null;
        var issueId = GetLinkedIssueId();

        if (string.IsNullOrEmpty(issueId))
            return;

        try
        {
            _linkedIssue = await IssueApi.GetIssueAsync(issueId, ProjectId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load linked issue {IssueId}", issueId);
        }
    }

    private async Task LoadCloneInfoAsync()
    {
        if (CurrentPr == null) return;

        _cloneInfo = null;
        _branchInfo = null;

        _project = CurrentPr.Project ?? await ProjectApi.GetProjectAsync(CurrentPr.ProjectId);

        if (_project == null || string.IsNullOrEmpty(CurrentPr.ClonePath))
            return;

        try
        {
            var clones = await CloneApi.ListClonesAsync(CurrentPr.ProjectId);
            _cloneInfo = clones.FirstOrDefault(w => w.Path == CurrentPr.ClonePath);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load clone info for PR {PullRequestId}", CurrentPr.Id);
        }
    }

    private async Task RefreshSessionStatusAsync()
    {
        if (CurrentPr != null)
        {
            _session = await SessionStoreApi.GetSessionByEntityIdAsync(CurrentPr.Id);
        }
    }

    private void OnModelChanged(string modelId)
    {
        _selectedModel = modelId;
    }

    private async Task HandleAgentStart(AgentPrompt? selectedPrompt)
    {
        await StartSession(selectedPrompt);
    }

    private async Task StartSession(AgentPrompt? prompt)
    {
        if (_isStarting || CurrentPr == null) return;
        _isStarting = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var clonePath = CurrentPr.ClonePath;

            if (string.IsNullOrEmpty(clonePath) && !string.IsNullOrEmpty(CurrentPr.BranchName) && CurrentPr.Project != null)
            {
                var cloneExistsResult = await CloneApi.CheckCloneExistsAsync(CurrentPr.ProjectId, CurrentPr.BranchName);

                if (cloneExistsResult?.Exists == true)
                {
                    var clones = await CloneApi.ListClonesAsync(CurrentPr.ProjectId);
                    var existingClone = clones.FirstOrDefault(c =>
                        c.Branch?.Replace("refs/heads/", "") == CurrentPr.BranchName);
                    clonePath = existingClone?.Path;

                    if (!string.IsNullOrEmpty(clonePath))
                    {
                        try { await CloneApi.PullCloneAsync(clonePath); }
                        catch { Logger.LogWarning("Failed to pull latest changes, continuing anyway"); }
                    }
                }
                else
                {
                    var createResult = await CloneApi.CreateCloneAsync(new CreateCloneRequest
                    {
                        ProjectId = CurrentPr.ProjectId,
                        BranchName = CurrentPr.BranchName,
                        CreateBranch = false
                    });
                    clonePath = createResult?.Path;
                }

                if (!string.IsNullOrEmpty(clonePath))
                {
                    CurrentPr.ClonePath = clonePath;
                    await PullRequestApi.UpdatePullRequestAsync(CurrentPr.Id, new UpdatePullRequestRequest
                    {
                        BranchName = CurrentPr.BranchName
                    });
                }
            }

            if (string.IsNullOrEmpty(clonePath))
            {
                _errorMessage = "Unable to create or find clone for this pull request.";
                return;
            }

            var mode = prompt?.Mode ?? SessionMode.Build;

            var systemPrompt = GenerateSystemPrompt();
            _session = await SessionApi.CreateSessionAsync(new CreateSessionRequest
            {
                EntityId = CurrentPr.Id,
                ProjectId = CurrentPr.ProjectId,
                WorkingDirectory = clonePath,
                Mode = mode,
                Model = _selectedModel,
                SystemPrompt = systemPrompt
            });

            if (_session != null && prompt != null && !string.IsNullOrEmpty(prompt.InitialMessage))
            {
                await SessionApi.SendMessageAsync(_session.Id, new SendMessageRequest
                {
                    Message = prompt.InitialMessage
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start session for PR {PullRequestId}", CurrentPr.Id);
            _errorMessage = $"Failed to start session: {ex.Message}";
            _session = null;
        }
        finally
        {
            _isStarting = false;
            StateHasChanged();
        }
    }

    private string? GenerateSystemPrompt()
    {
        if (CurrentPr == null) return null;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"You are working on PR: {CurrentPr.Title}");

        if (!string.IsNullOrEmpty(CurrentPr.Description))
        {
            sb.AppendLine();
            sb.AppendLine("PR Description:");
            sb.AppendLine(CurrentPr.Description);
        }

        if (!string.IsNullOrEmpty(CurrentPr.BranchName))
        {
            sb.AppendLine();
            sb.AppendLine($"Branch: {CurrentPr.BranchName}");
        }

        if (_linkedIssue != null)
        {
            sb.AppendLine();
            sb.AppendLine($"Linked Issue: {_linkedIssue.Id}");
            sb.AppendLine($"Issue Title: {_linkedIssue.Title}");
            sb.AppendLine($"Issue Type: {_linkedIssue.Type}");
            sb.AppendLine($"Issue Status: {_linkedIssue.Status}");
            if (!string.IsNullOrEmpty(_linkedIssue.Description))
            {
                sb.AppendLine($"Issue Description: {_linkedIssue.Description}");
            }
        }

        return sb.ToString();
    }

    private async Task StopSession()
    {
        if (_session == null) return;

        _isSessionLoading = true;
        _errorMessage = null;
        try
        {
            await SessionApi.StopSessionAsync(_session.Id);
            _session = null;
            await OnActionCompleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSessionLoading = false;
        }
    }

    private async Task StartRebaseAsync()
    {
        if (_project == null || _cloneInfo == null || CurrentPr == null)
        {
            _errorMessage = "Project or clone not available.";
            return;
        }

        _isRebasing = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            _errorMessage = "Rebase agent is not available in the browser client. Please use the server application.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start rebase agent for PR {PullRequestId}", CurrentPr.Id);
            _errorMessage = $"Failed to start rebase agent: {ex.Message}";
        }
        finally
        {
            _isRebasing = false;
            StateHasChanged();
        }
    }

    private bool StartSessionDisabled => CurrentPr == null || string.IsNullOrEmpty(CurrentPr.BranchName) || _isStarting;

    private async Task SkipReview()
    {
        if (CurrentPr == null) return;

        _isLoading = true;
        _errorMessage = null;
        try
        {
            await PullRequestApi.UpdatePullRequestAsync(CurrentPr.Id, new UpdatePullRequestRequest
            {
                Status = OpenPullRequestStatus.InDevelopment
            });
            await OnActionCompleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task MergePullRequest()
    {
        if (CurrentPr?.GitHubPRNumber == null)
        {
            _errorMessage = "No GitHub PR linked to this pull request.";
            return;
        }

        _isLoading = true;
        _errorMessage = null;
        try
        {
            if (_session != null)
            {
                await SessionApi.StopSessionAsync(_session.Id);
                _session = null;
            }

            await PullRequestApi.SyncPullRequestsAsync(CurrentPr.ProjectId);
            await PullRequestApi.DeletePullRequestAsync(CurrentPr.Id);
            await OnActionCompleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void HandleClose()
    {
        OnClose.InvokeAsync();
    }

    private string GetStatusBadgeClass()
    {
        return CurrentPr?.Status switch
        {
            OpenPullRequestStatus.InDevelopment => "bg-primary text-primary-foreground border-transparent",
            OpenPullRequestStatus.ReadyForReview => "bg-amber-500 text-white border-transparent",
            OpenPullRequestStatus.HasReviewComments => "bg-destructive text-destructive-foreground border-transparent",
            OpenPullRequestStatus.Approved => "bg-green-600 text-white border-transparent",
            _ => "bg-secondary text-secondary-foreground border-transparent"
        };
    }

    private string GetSessionStatusBadgeClass() => _session?.Status.ToBbBadgeClass() ?? "bg-secondary text-secondary-foreground border-transparent";

    private static string GetModelDisplayName(string model)
    {
        var parts = model.Split('/');
        return parts.Length > 1 ? parts[1] : model;
    }

    private static string GetIssueTypeBadgeClass(IssueType type) => type switch
    {
        IssueType.Feature => "bg-primary text-primary-foreground border-transparent",
        IssueType.Bug => "bg-destructive text-destructive-foreground border-transparent",
        IssueType.Task => "bg-blue-500 text-white border-transparent",
        IssueType.Chore => "bg-secondary text-secondary-foreground border-transparent",
        _ => "bg-secondary text-secondary-foreground border-transparent"
    };

    private static string GetIssueStatusBadgeClass(IssueStatus status) => status switch
    {
        IssueStatus.Open => "bg-blue-500 text-white border-transparent",
        IssueStatus.Progress => "bg-primary text-primary-foreground border-transparent",
        IssueStatus.Review => "bg-blue-500 text-white border-transparent",
        IssueStatus.Complete => "bg-green-600 text-white border-transparent",
        IssueStatus.Closed => "bg-green-600 text-white border-transparent",
        _ => "bg-secondary text-secondary-foreground border-transparent"
    };

    private async Task SetupSignalRConnectionAsync()
    {
        if (CurrentPr == null) return;

        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/claudecode"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<ClaudeSession>("SessionStarted", async (session) =>
            {
                if (session.EntityId == CurrentPr?.Id)
                {
                    await InvokeAsync(() =>
                    {
                        _session = session;
                        _isStarting = false;
                        StateHasChanged();
                    });
                }
            });

            _hubConnection.On<string, ClaudeSessionStatus, bool>("SessionStatusChanged", async (sessionId, status, _) =>
            {
                if (_session?.Id == sessionId)
                {
                    await InvokeAsync(async () =>
                    {
                        _session = await SessionStoreApi.GetSessionByEntityIdAsync(CurrentPr!.Id);
                        StateHasChanged();
                    });
                }
            });

            _hubConnection.On<string>("SessionStopped", async (sessionId) =>
            {
                if (_session?.Id == sessionId)
                {
                    await InvokeAsync(() =>
                    {
                        _session = null;
                        StateHasChanged();
                    });
                }
            });

            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to set up SignalR connection for InlinePrDetailRow");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            try
            {
                await _hubConnection.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }
    }
}
