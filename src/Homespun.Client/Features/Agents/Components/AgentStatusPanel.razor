@implements IAsyncDisposable

@inject HttpSessionApiService SessionStoreApi

<BbCard Class="@(IsRunning ? "border-[var(--status-success)]" : "")">
    <BbCardHeader>
        <div class="d-flex justify-content-between align-items-center">
            <BbCardTitle>Claude Code Session</BbCardTitle>
            @if (IsRunning)
            {
                <span class="status-dot-running"></span>
            }
        </div>
    </BbCardHeader>

    @if (IsLoading)
    {
        <BbCardContent>
            <div class="flex justify-center py-3">
                <BbSpinner Size="SpinnerSize.Small" />
            </div>
        </BbCardContent>
    }
    else if (_session != null)
    {
        <BbCardContent>
            <div>
                <small class="text-text-muted">
                    Mode: <BbBadge Class="@(_session.Mode == SessionMode.Plan ? "bg-blue-500 text-white border-transparent ml-1" : "bg-green-600 text-white border-transparent ml-1")">@_session.Mode</BbBadge>
                </small>
                <small class="text-text-muted block">
                    Model: <code class="text-xs">@GetModelDisplayName(_session.Model)</code>
                </small>
                <small class="text-text-muted block">
                    Status: <code class="text-xs">@_session.Status</code>
                </small>
            </div>

            @if (_session.Messages.Count > 0)
            {
                <div class="mt-2 text-xs text-[var(--text-secondary)]">
                    <small class="text-text-muted">Messages: @_session.Messages.Count</small>
                </div>
            }
        </BbCardContent>
        <BbCardFooter>
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Class="mr-2" Href="@($"/session/{_session.Id}")">
                Open Chat
            </BbButton>
            <BbButton Variant="ButtonVariant.Destructive" Size="ButtonSize.Small" OnClick="StopSession" Disabled="@IsLoading">
                Stop Session
            </BbButton>
        </BbCardFooter>
    }
    else
    {
        <BbCardContent>
            <p class="text-text-muted text-sm mb-0">No session active.</p>
        </BbCardContent>
        @if (CanStart)
        {
            <BbCardFooter>
                <div class="mb-2">
                    <ModelSelector Id="@($"agent-{EntityId}")"
                                 SelectedModel="@_selectedModel"
                                 SelectedModelChanged="OnModelChanged" />
                </div>
                <div class="flex gap-2">
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="StartPlanning" Disabled="@IsLoading" title="Read-only planning session">
                        Plan
                    </BbButton>
                    <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" OnClick="StartBuilding" Disabled="@IsLoading" title="Full code editing session">
                        Build
                    </BbButton>
                </div>
            </BbCardFooter>
        }
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <BbCardContent Class="pt-0">
            <BbAlert Variant="AlertVariant.Danger" Class="mb-0">
                <BbAlertDescription>@ErrorMessage</BbAlertDescription>
            </BbAlert>
        </BbCardContent>
    }
</BbCard>

<style>
    .status-dot-running {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--status-success);
        animation: pulse 1.5s ease-in-out infinite;
    }
</style>

@code {
    [Parameter] public string EntityId { get; set; } = "";
    [Parameter] public bool CanStart { get; set; } = true;
    [Parameter] public EventCallback OnStatusChanged { get; set; }

    private ClaudeSession? _session;
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }
    private string _selectedModel = "opus";

    private bool IsRunning => _session != null && _session.Status.IsActive();

    protected override async Task OnParametersSetAsync()
    {
        await RefreshStatusAsync();
    }

    private async Task RefreshStatusAsync()
    {
        if (string.IsNullOrEmpty(EntityId))
        {
            _session = null;
            return;
        }

        try
        {
            _session = await SessionStoreApi.GetSessionByEntityIdAsync(EntityId);
        }
        catch
        {
            // Session lookup failed, assume no active session
            _session = null;
        }
    }

    private void OnModelChanged(string modelId)
    {
        _selectedModel = modelId;
    }

    private void StartPlanning()
    {
        // TODO: Integrate with session creation via SessionStoreApi
        ErrorMessage = "Session service not yet implemented. Coming soon!";
    }

    private void StartBuilding()
    {
        // TODO: Integrate with session creation via SessionStoreApi
        ErrorMessage = "Session service not yet implemented. Coming soon!";
    }

    private async Task StopSession()
    {
        if (_session == null) return;

        IsLoading = true;
        ErrorMessage = null;
        try
        {
            // TODO: Integrate with ClaudeSessionService in Phase 5
            await SessionStoreApi.StopSessionAsync(_session.Id);
            _session = null;
            await OnStatusChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static string GetModelDisplayName(string model)
    {
        var parts = model.Split('/');
        return parts.Length > 1 ? parts[1] : model;
    }

    public ValueTask DisposeAsync()
    {
        return ValueTask.CompletedTask;
    }
}
