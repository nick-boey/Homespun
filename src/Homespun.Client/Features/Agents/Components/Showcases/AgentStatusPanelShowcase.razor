@*
    AgentStatusPanel showcase - renders the real component with entity IDs that won't match any session.
*@

<BbCard>
    <BbCardHeader>
        <BbCardTitle>No Active Session</BbCardTitle>
        <BbCardDescription>Panel with no matching session (start controls hidden)</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <div style="max-width: 300px;">
            <AgentStatusPanel EntityId="showcase-no-session" CanStart="false" />
        </div>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>With Start Controls</BbCardTitle>
        <BbCardDescription>Panel with model selector and Plan/Build buttons</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <div style="max-width: 300px;">
            <AgentStatusPanel EntityId="showcase-with-start" CanStart="true" />
        </div>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Session Status Badges</BbCardTitle>
        <BbCardDescription>Different session states</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <div class="d-flex flex-column gap-3">
            <div class="d-flex align-items-center gap-2">
                <BbBadge Class="bg-green-600 text-white border-transparent" style="min-width: 120px;">Running</BbBadge>
                <span class="text-text-muted text-sm">Agent is actively working</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <BbBadge Class="bg-amber-500 text-white border-transparent" style="min-width: 120px;">WaitingForInput</BbBadge>
                <span class="text-text-muted text-sm">Agent needs user response</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <BbBadge Variant="BadgeVariant.Secondary" style="min-width: 120px;">Completed</BbBadge>
                <span class="text-text-muted text-sm">Session has finished</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <BbBadge Variant="BadgeVariant.Destructive" style="min-width: 120px;">Error</BbBadge>
                <span class="text-text-muted text-sm">Session encountered an error</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <BbBadge Class="bg-blue-500 text-white border-transparent" style="min-width: 120px;">Starting</BbBadge>
                <span class="text-text-muted text-sm">Session is initializing</span>
            </div>
        </div>
    </BbCardContent>
</BbCard>

