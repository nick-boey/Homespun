<BbCard>
    <BbCardHeader>
        <BbCardTitle>Working Agents Only</BbCardTitle>
        <BbCardDescription>Shows active working agents</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <AgentStatusIndicator WorkingCount="2" WaitingCount="0"/>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Waiting Agents Only</BbCardTitle>
        <BbCardDescription>Shows agents waiting for input</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <AgentStatusIndicator WorkingCount="0" WaitingCount="3"/>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Question and Plan Ready</BbCardTitle>
        <BbCardDescription>Shows agents awaiting response and with plan ready</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <AgentStatusIndicator WorkingCount="0" QuestionCount="1" PlanReadyCount="2" WaitingCount="0"/>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Mixed Status</BbCardTitle>
        <BbCardDescription>Working, question, plan ready, and waiting agents</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <AgentStatusIndicator WorkingCount="1" QuestionCount="1" PlanReadyCount="1" WaitingCount="2"/>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>No Active Agents</BbCardTitle>
        <BbCardDescription>Nothing shown when no agents are active</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <AgentStatusIndicator WorkingCount="0" WaitingCount="0"/>
        <span class="text-text-muted text-sm">(indicator is hidden when no agents are active)</span>
    </BbCardContent>
</BbCard>
