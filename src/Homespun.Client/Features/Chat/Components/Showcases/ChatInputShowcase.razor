<BbCard>
    <BbCardHeader>
        <BbCardTitle>Default State</BbCardTitle>
        <BbCardDescription>Empty input ready for typing</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <ChatInput
            Value="@_value1"
            ValueChanged="@(v => _value1 = v)"
            OnSend="@(_ => { })"/>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>With Content</BbCardTitle>
        <BbCardDescription>Input with pre-filled text</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <ChatInput
            Value="@_value2"
            ValueChanged="@(v => _value2 = v)"
            OnSend="@(_ => { })"/>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Custom Placeholder</BbCardTitle>
        <BbCardDescription>Input with custom placeholder text</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <ChatInput
            Value="@_value3"
            ValueChanged="@(v => _value3 = v)"
            Placeholder="Describe the feature you want to implement..."
            OnSend="@(_ => { })"/>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Disabled State</BbCardTitle>
        <BbCardDescription>Input disabled while processing</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <ChatInput
            Value="@_value4"
            ValueChanged="@(v => _value4 = v)"
            Disabled="true"
            Placeholder="Waiting for response..."
            OnSend="@(_ => { })"/>
    </BbCardContent>
</BbCard>

@code {
    private string _value1 = "";
    private string _value2 = "Can you help me fix the failing tests?";
    private string _value3 = "";
    private string _value4 = "Processing your request...";
}
