<div class="w-full">
    <BbTextarea
        Placeholder="@Placeholder"
        Disabled="@Disabled"
        AriaLabel="Chat message input"
        @bind-Value="Value"
        @onkeydown="HandleKeyDown">
    </BbTextarea>
    <div class="flex items-center justify-between mt-1">
        <span class="text-xs text-[var(--text-muted)]">Ctrl+Enter to send</span>
        <BbButton Variant="ButtonVariant.Default"
                  OnClick="HandleSend"
                  Disabled="@(string.IsNullOrWhiteSpace(Value) || Disabled)"
                  aria-label="Send message">
            <LucideIcon Name="send-horizontal"/>
        </BbButton>
    </div>
</div>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;

    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    [Parameter] public string Placeholder { get; set; } = "Type a message...";

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public EventCallback<string> OnSend { get; set; }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", CtrlKey: true })
        {
            await HandleSend();
        }
    }

    private async Task HandleSend()
    {
        if (string.IsNullOrWhiteSpace(Value) || Disabled)
            return;

        var message = Value;
        Value = string.Empty;
        await ValueChanged.InvokeAsync(Value);
        await OnSend.InvokeAsync(message);
    }

}
