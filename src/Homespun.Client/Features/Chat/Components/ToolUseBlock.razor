<div class="bg-[var(--bg-tertiary)] p-1 rounded-sm font-mono text-sm">
    <div class="flex items-center gap-0.5 mb-0.5">
        <span aria-hidden="true">🔧</span>
        <span class="font-semibold">@ToolName</span>
        @if (IsStreaming)
        {
            <BbSpinner Size="SpinnerSize.Small" Class="ml-2" />
        }
    </div>
    @if (!string.IsNullOrEmpty(ToolInput))
    {
        <pre class="m-0 p-1 bg-[var(--bg-tool-group)] rounded-sm overflow-x-auto whitespace-pre-wrap break-words max-h-[200px] overflow-y-auto">@ToolInput@(IsStreaming ? "▌" : "")</pre>
    }
</div>

@code {
    [Parameter]
    public string? ToolName { get; set; }

    [Parameter]
    public string? ToolInput { get; set; }

    [Parameter]
    public bool IsStreaming { get; set; }
}
