# Homespun Environment Configuration
#
# Copy this file to `.env` at the repo root and fill in your values.
# This is the single source of deployment configuration, consumed by:
#   - scripts/run-komodo.sh                     (Komodo sidecar)
#   - scripts/deploy-infra.sh + infra/*.bicep   (Azure VM deployment)
#   - infra/cloud-init.yaml                     (writes this file onto the VM)
#
# Local dev uses dotnet user-secrets instead of .env — run
# `scripts/set-user-secrets.sh` (or `.ps1`) once after copying to .env to
# migrate GITHUB_TOKEN and CLAUDE_CODE_OAUTH_TOKEN into the Homespun.AppHost
# user-secrets store.

# Required: GitHub personal access token for PR synchronization
# Create at: https://github.com/settings/tokens (needs 'repo' scope)
GITHUB_TOKEN=ghp_your_token_here

# Required: Claude Code OAuth token for API authentication
# Run 'claude login' on the host machine to authenticate, then
# copy the token from ~/.claude/.credentials.json
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: Tailscale auth key for VPN access (shared sidecar)
# Consumed by run-komodo.sh to attach a Tailscale sidecar to homespun-net.
# Generate at: https://login.tailscale.com/admin/settings/keys
# TAILSCALE_AUTH_KEY=tskey-auth-your_key_here

# Optional: External hostname for agent URLs
# Makes agent links point to an external hostname instead of localhost
# HSP_EXTERNAL_HOSTNAME=homespun.example.com
